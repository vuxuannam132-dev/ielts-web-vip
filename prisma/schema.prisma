// This is your Prisma schema file
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ───────────────────────────────────────────────
// Auth & User Management
// ───────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  password      String

  // Role: USER | ADMIN | TEACHER
  role          String   @default("USER")
  // Tier: FREE | PRO | PREMIUM | EDU
  tier          String   @default("FREE")
  tierExpiresAt DateTime?

  // AI Budget tracking
  tokenUsage    Int      @default(0)
  aiUsedCount   Int      @default(0)
  tokenResetAt  DateTime @default(now())

  // Security
  loginAttempts Int      @default(0)
  lockedUntil   DateTime?
  lastLoginAt   DateTime?
  lastLoginIp   String?

  // Onboarding
  onboardingDone  Boolean  @default(false)
  currentBand     Float?
  weakestSkill    String?  // LISTENING | READING | WRITING | SPEAKING

  // Gamification & Stats
  targetBand            Float?
  lifetimePracticeCount Int      @default(0)
  currentStreak         Int      @default(0)
  highestStreak         Int      @default(0)
  lastPracticeDate      DateTime?

  // Band Estimation
  estimatedBand         Float?   // calculated from first 4 skill submissions
  bandReminderShown     Boolean  @default(false)

  submissions   Submission[]
  classesAsTeacher Class[]  @relation("TeacherClasses")
  classMembers  ClassMember[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ───────────────────────────────────────────────
// IELTS Content
// ───────────────────────────────────────────────

model PracticeSet {
  id          String    @id @default(cuid())
  skill       String    // LISTENING | READING | WRITING | SPEAKING
  title       String
  description String?
  difficulty  String    @default("Medium")
  isDaily     Boolean   @default(false)
  activeDate  DateTime?
  content     String?   // JSON structured content
  isAIGenerated Boolean @default(false)
  isActive    Boolean   @default(true)

  // Class-specific content (null = public)
  classId     String?
  class       Class?   @relation(fields: [classId], references: [id])

  submissions  Submission[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Submission {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  practiceSetId String?
  practiceSet   PracticeSet? @relation(fields: [practiceSetId], references: [id])

  skill         String
  answers       String   // JSON
  bandScore     Float?
  feedback      String?  // JSON
  transcript    String?
  timeTaken     Int?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ───────────────────────────────────────────────
// Teacher System & Classes
// ───────────────────────────────────────────────

model Class {
  id          String @id @default(cuid())
  name        String
  description String?
  teacherId   String
  teacher     User   @relation("TeacherClasses", fields: [teacherId], references: [id], onDelete: Cascade)
  inviteCode  String @unique @default(cuid())
  isActive    Boolean @default(true)

  members     ClassMember[]
  practiceSets PracticeSet[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ClassMember {
  id        String @id @default(cuid())
  classId   String
  class     Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String @default("PENDING") // PENDING | APPROVED | REJECTED
  joinedAt  DateTime @default(now())

  @@unique([classId, userId])
}

// ───────────────────────────────────────────────
// System & Payment Configuration
// ───────────────────────────────────────────────

model SystemConfig {
  key       String @id
  value     String
  updatedAt DateTime @updatedAt @default(now())
}

model Package {
  id          String   @id @default(cuid())
  code        String   @unique // FREE | PRO | PREMIUM | EDU
  name        String
  price       Int
  durationDays Int?
  description String
  benefits    String   // JSON array
  isActive    Boolean  @default(true)
  requiresManualApproval Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Payment transactions
model Transaction {
  id            String @id @default(cuid())
  userId        String
  packageCode   String
  amount        Int
  transferContent String
  status        String @default("PENDING") // PENDING | SUCCESS | FAILED
  cassoId       String? // Casso transaction reference
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
