# 1. Database (PostgreSQL required for Vercel, e.g. Neon.tech or Supabase)
DATABASE_URL="postgresql://user:password@host/database_name?sslmode=require"

# 2. NextAuth Secret (Generate via: openssl rand -base64 32)
AUTH_SECRET="your-generated-secret-here"

# 3. NextAuth Base Route
NEXTAUTH_URL="https://your-custom-domain.com"
NEXTAUTH_SECRET="your-generated-secret-here" # Same as AUTH_SECRET

# 4. OpenAI API Key for Examiner Grading
OPENAI_API_KEY="sk-proj-your-api-key-here"

# 5. Stripe Keys (Optional, configurable in Admin panel later)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
